# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production

# ─── Database ────────────────────────────────────────────────────────────────
# BUG FIX: use 'postgres' (container name) not 'localhost' when running via Docker
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/ai_platform

# ─── Redis ───────────────────────────────────────────────────────────────────
# BUG FIX: use 'redis' (container name) not 'localhost' when running via Docker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── OpenAI (fallback only) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ─── Local LLM (Ollama) ──────────────────────────────────────────────────────
LOCAL_LLM_URL=http://ollama:11434
LOCAL_LLM_MODEL=mistral

# ─── WhatsApp Business API ───────────────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# BUG FIX: App Secret is required for HMAC webhook signature validation
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Decision Engine Thresholds ──────────────────────────────────────────────
TEMPLATE_CONFIDENCE_THRESHOLD=0.85
LOCAL_LLM_CONFIDENCE_THRESHOLD=0.70
