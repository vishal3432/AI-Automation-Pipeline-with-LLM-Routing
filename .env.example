# App
DEBUG=false
SECRET_KEY=                                         

# Database
POSTGRES_USER=                                      
POSTGRES_PASSWORD=                                  
POSTGRES_DB=ai_platform
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@postgres:5432/ai_platform

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OpenAI (fallback only)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=llama3-8b-8192       # OPENAI_MODEL=gpt-3.5-turbo(will use it when comes to paid tier ,but as of now using groq )

# Local LLM (Ollama)
LOCAL_LLM_URL=http://ollama:11434
LOCAL_LLM_MODEL=mistral

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=your-whatsapp-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-whatsapp-app-secret       # required for HMAC webhook signature validation

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Decision Engine Thresholds
TEMPLATE_CONFIDENCE_THRESHOLD=0.85
LOCAL_LLM_CONFIDENCE_THRESHOLD=0.70

# Flower Dashboard Auth
FLOWER_USER=admin
FLOWER_PASSWORD=                                    

# CORS / Trusted Hosts
ALLOWED_ORIGINS=["*"]         # ["https://yourdomain.com"]
ALLOWED_HOSTS=["*"]          # ["yourdomain.com"]
